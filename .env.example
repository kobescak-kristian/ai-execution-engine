# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=crm_workflow.db

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Required for AI-powered agent recommendations.
# If not set, the system falls back to deterministic rule-based analysis.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ─── Workflow Timing Thresholds ───────────────────────────────────────────────
FOLLOW_UP_THRESHOLD_DAYS=3
STUCK_LEAD_THRESHOLD_DAYS=7
AGING_LEAD_THRESHOLD_DAYS=14

# ─── Routing Score Thresholds ─────────────────────────────────────────────────
ENTERPRISE_SCORE_THRESHOLD=70
SMB_SCORE_THRESHOLD=40
MANUAL_REVIEW_SCORE_THRESHOLD=20

# ─── Agent Trigger Thresholds ─────────────────────────────────────────────────
AGENT_MANUAL_REVIEW_THRESHOLD=0.20
AGENT_CONVERSION_WARNING_THRESHOLD=0.10
AGENT_STUCK_LEAD_WARNING_COUNT=5
